ENVIRONMENT=development

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=taskforge
POSTGRES_USER=taskforge
POSTGRES_PASSWORD=taskforge_secret

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TASK_EVENTS_TOPIC=task.events
KAFKA_WORKFLOW_EVENTS_TOPIC=workflow.events
KAFKA_NOTIFICATIONS_TOPIC=notifications

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# gRPC Services
TASK_SERVICE_HOST=localhost
TASK_SERVICE_PORT=50051
WORKFLOW_SERVICE_HOST=localhost
WORKFLOW_SERVICE_PORT=50052
NOTIFICATION_SERVICE_HOST=localhost
NOTIFICATION_SERVICE_PORT=50053

# JWT
JWT_SECRET_KEY=your_super_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=taskforge

# Logging
LOG_LEVEL=DEBUG